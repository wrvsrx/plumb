{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "plumb",
  "word": "attribute_name",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_block"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          }
        ]
      }
    },
    "_block": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "code_block"
        },
        {
          "type": "SYMBOL",
          "name": "marked_block"
        },
        {
          "type": "SYMBOL",
          "name": "paragraph"
        }
      ]
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "\\n"
    },
    "marked_block": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "introducer",
            "content": {
              "type": "SYMBOL",
              "name": "introducer"
            }
          },
          {
            "type": "FIELD",
            "name": "marker",
            "content": {
              "type": "SYMBOL",
              "name": "marker"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "attributes",
                "content": {
                  "type": "SYMBOL",
                  "name": "attributes"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "head_separator"
                  },
                  {
                    "type": "FIELD",
                    "name": "head",
                    "content": {
                      "type": "SYMBOL",
                      "name": "inline_content"
                    }
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_line_end"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "FIELD",
                    "name": "continued_head",
                    "content": {
                      "type": "SYMBOL",
                      "name": "headed_body"
                    }
                  },
                  {
                    "type": "FIELD",
                    "name": "body",
                    "content": {
                      "type": "SYMBOL",
                      "name": "block_body"
                    }
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "headed_body": {
      "type": "PREC_RIGHT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_indent"
          },
          {
            "type": "FIELD",
            "name": "continuation",
            "content": {
              "type": "SYMBOL",
              "name": "head_continuation"
            }
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_same_indent"
                },
                {
                  "type": "FIELD",
                  "name": "continuation",
                  "content": {
                    "type": "SYMBOL",
                    "name": "head_continuation"
                  }
                }
              ]
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "REPEAT1",
                        "content": {
                          "type": "SYMBOL",
                          "name": "blank_line"
                        }
                      },
                      {
                        "type": "CHOICE",
                        "members": [
                          {
                            "type": "SEQ",
                            "members": [
                              {
                                "type": "SYMBOL",
                                "name": "_same_indent"
                              },
                              {
                                "type": "FIELD",
                                "name": "child",
                                "content": {
                                  "type": "SYMBOL",
                                  "name": "_block"
                                }
                              },
                              {
                                "type": "REPEAT",
                                "content": {
                                  "type": "CHOICE",
                                  "members": [
                                    {
                                      "type": "SYMBOL",
                                      "name": "blank_line"
                                    },
                                    {
                                      "type": "SEQ",
                                      "members": [
                                        {
                                          "type": "SYMBOL",
                                          "name": "_same_indent"
                                        },
                                        {
                                          "type": "FIELD",
                                          "name": "child",
                                          "content": {
                                            "type": "SYMBOL",
                                            "name": "_block"
                                          }
                                        }
                                      ]
                                    }
                                  ]
                                }
                              }
                            ]
                          },
                          {
                            "type": "BLANK"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "SEQ",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "_same_indent"
                      },
                      {
                        "type": "FIELD",
                        "name": "child",
                        "content": {
                          "type": "CHOICE",
                          "members": [
                            {
                              "type": "SYMBOL",
                              "name": "marked_block"
                            },
                            {
                              "type": "SYMBOL",
                              "name": "code_block"
                            }
                          ]
                        }
                      },
                      {
                        "type": "REPEAT",
                        "content": {
                          "type": "CHOICE",
                          "members": [
                            {
                              "type": "SYMBOL",
                              "name": "blank_line"
                            },
                            {
                              "type": "SEQ",
                              "members": [
                                {
                                  "type": "SYMBOL",
                                  "name": "_same_indent"
                                },
                                {
                                  "type": "FIELD",
                                  "name": "child",
                                  "content": {
                                    "type": "SYMBOL",
                                    "name": "_block"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      }
                    ]
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_dedent"
          }
        ]
      }
    },
    "head_continuation": {
      "type": "PREC",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "content",
            "content": {
              "type": "SYMBOL",
              "name": "inline_content"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_line_end"
          }
        ]
      }
    },
    "block_body": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "blank_line"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_indent"
          },
          {
            "type": "SYMBOL",
            "name": "_block"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "blank_line"
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "SYMBOL",
                      "name": "_same_indent"
                    },
                    {
                      "type": "SYMBOL",
                      "name": "_block"
                    }
                  ]
                }
              ]
            }
          },
          {
            "type": "SYMBOL",
            "name": "_dedent"
          }
        ]
      }
    },
    "code_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "introducer",
          "content": {
            "type": "SYMBOL",
            "name": "introducer"
          }
        },
        {
          "type": "FIELD",
          "name": "marker",
          "content": {
            "type": "SYMBOL",
            "name": "code_marker"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "attributes",
              "content": {
                "type": "SYMBOL",
                "name": "attributes"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        },
        {
          "type": "FIELD",
          "name": "body",
          "content": {
            "type": "REPEAT1",
            "content": {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "raw_code_line"
              },
              "named": true,
              "value": "raw_text"
            }
          }
        }
      ]
    },
    "paragraph": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "inline_content"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        }
      ]
    },
    "inline_content": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "introducer_escape"
          },
          {
            "type": "SYMBOL",
            "name": "inline_verbatim"
          },
          {
            "type": "SYMBOL",
            "name": "inline_element"
          },
          {
            "type": "SYMBOL",
            "name": "text"
          }
        ]
      }
    },
    "inline_element": {
      "type": "PREC_RIGHT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "introducer",
            "content": {
              "type": "SYMBOL",
              "name": "introducer"
            }
          },
          {
            "type": "FIELD",
            "name": "kind",
            "content": {
              "type": "SYMBOL",
              "name": "inline_kind"
            }
          },
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "SYMBOL",
                  "name": "inline_content"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "STRING",
            "value": "]"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "attributes",
                "content": {
                  "type": "SYMBOL",
                  "name": "attributes"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "inline_verbatim": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "source",
          "content": {
            "type": "SYMBOL",
            "name": "_inline_verbatim_token"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "attributes",
              "content": {
                "type": "SYMBOL",
                "name": "attributes"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "attributes": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "tag",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_tag"
                }
              },
              {
                "type": "FIELD",
                "name": "id",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_id"
                }
              },
              {
                "type": "FIELD",
                "name": "class",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_class"
                }
              },
              {
                "type": "FIELD",
                "name": "pair",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_pair"
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "attribute_tag": {
      "type": "SYMBOL",
      "name": "attribute_name"
    },
    "attribute_id": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        }
      ]
    },
    "attribute_class": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        }
      ]
    },
    "attribute_pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_name"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_value"
          }
        }
      ]
    },
    "attribute_name": {
      "type": "PATTERN",
      "value": "[^\\s{}#.=]+"
    },
    "attribute_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^\\s{}\"]+"
        },
        {
          "type": "PATTERN",
          "value": "\"([^\"\\\\]|\\\\.)*\""
        }
      ]
    },
    "introducer_escape": {
      "type": "PREC",
      "value": 3,
      "content": {
        "type": "STRING",
        "value": "``"
      }
    },
    "introducer": {
      "type": "STRING",
      "value": "`"
    },
    "marker": {
      "type": "PATTERN",
      "value": "[^\\s\\[{`\"]+"
    },
    "inline_kind": {
      "type": "PATTERN",
      "value": "[^\\s\\[{`\"]+"
    },
    "head_separator": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]+"
        }
      }
    },
    "text": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "PATTERN",
        "value": "[^`\\]\\n]+|\\]"
      }
    },
    "_line_end": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "\n"
        },
        {
          "type": "SYMBOL",
          "name": "_eof"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_indent"
    },
    {
      "type": "SYMBOL",
      "name": "_same_indent"
    },
    {
      "type": "SYMBOL",
      "name": "_dedent"
    },
    {
      "type": "SYMBOL",
      "name": "code_marker"
    },
    {
      "type": "SYMBOL",
      "name": "raw_code_line"
    },
    {
      "type": "SYMBOL",
      "name": "_inline_verbatim_token"
    },
    {
      "type": "SYMBOL",
      "name": "_eof"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}