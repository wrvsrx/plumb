{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "plumb",
  "word": "attribute_name",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_block"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          }
        ]
      }
    },
    "_block": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "code_block"
        },
        {
          "type": "SYMBOL",
          "name": "marked_block"
        },
        {
          "type": "SYMBOL",
          "name": "paragraph"
        }
      ]
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "\\n"
    },
    "marked_block": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "introducer",
            "content": {
              "type": "SYMBOL",
              "name": "introducer"
            }
          },
          {
            "type": "FIELD",
            "name": "marker",
            "content": {
              "type": "SYMBOL",
              "name": "marker"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "attributes",
                "content": {
                  "type": "SYMBOL",
                  "name": "attributes"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "head_separator"
                  },
                  {
                    "type": "FIELD",
                    "name": "head",
                    "content": {
                      "type": "SYMBOL",
                      "name": "inline_content"
                    }
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_line_end"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "body",
                "content": {
                  "type": "SYMBOL",
                  "name": "indented_body"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "code_block": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "introducer",
            "content": {
              "type": "SYMBOL",
              "name": "introducer"
            }
          },
          {
            "type": "FIELD",
            "name": "marker",
            "content": {
              "type": "SYMBOL",
              "name": "code_marker"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "attributes",
                "content": {
                  "type": "SYMBOL",
                  "name": "attributes"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_line_end"
          },
          {
            "type": "FIELD",
            "name": "body",
            "content": {
              "type": "REPEAT1",
              "content": {
                "type": "SYMBOL",
                "name": "code_line"
              }
            }
          }
        ]
      }
    },
    "indented_body": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "blank_line"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "indented_marked_block"
              },
              {
                "type": "SYMBOL",
                "name": "indented_code_block"
              },
              {
                "type": "SYMBOL",
                "name": "indented_paragraph"
              }
            ]
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "indented_marked_block"
                },
                {
                  "type": "SYMBOL",
                  "name": "indented_code_block"
                },
                {
                  "type": "SYMBOL",
                  "name": "indented_paragraph"
                },
                {
                  "type": "SYMBOL",
                  "name": "blank_line"
                }
              ]
            }
          }
        ]
      }
    },
    "indented_marked_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "indent",
          "content": {
            "type": "SYMBOL",
            "name": "indent"
          }
        },
        {
          "type": "FIELD",
          "name": "block",
          "content": {
            "type": "SYMBOL",
            "name": "marked_block"
          }
        }
      ]
    },
    "indented_code_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "indent",
          "content": {
            "type": "SYMBOL",
            "name": "indent"
          }
        },
        {
          "type": "FIELD",
          "name": "block",
          "content": {
            "type": "SYMBOL",
            "name": "code_block"
          }
        }
      ]
    },
    "indented_paragraph": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "indent",
          "content": {
            "type": "SYMBOL",
            "name": "indent"
          }
        },
        {
          "type": "FIELD",
          "name": "block",
          "content": {
            "type": "SYMBOL",
            "name": "paragraph"
          }
        }
      ]
    },
    "paragraph": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "content",
          "content": {
            "type": "SYMBOL",
            "name": "inline_content"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        }
      ]
    },
    "code_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "indent",
          "content": {
            "type": "SYMBOL",
            "name": "indent"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "content",
              "content": {
                "type": "ALIAS",
                "content": {
                  "type": "SYMBOL",
                  "name": "raw_line"
                },
                "named": true,
                "value": "raw_text"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_line_end"
        }
      ]
    },
    "inline_content": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "introducer_escape"
          },
          {
            "type": "SYMBOL",
            "name": "inline_verbatim"
          },
          {
            "type": "SYMBOL",
            "name": "inline_element"
          },
          {
            "type": "SYMBOL",
            "name": "text"
          }
        ]
      }
    },
    "inline_element": {
      "type": "PREC_RIGHT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "introducer",
            "content": {
              "type": "SYMBOL",
              "name": "introducer"
            }
          },
          {
            "type": "FIELD",
            "name": "kind",
            "content": {
              "type": "SYMBOL",
              "name": "inline_kind"
            }
          },
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "SYMBOL",
                  "name": "inline_content"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "STRING",
            "value": "]"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "attributes",
                "content": {
                  "type": "SYMBOL",
                  "name": "attributes"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "inline_verbatim": {
      "type": "PREC",
      "value": 3,
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "`\"["
              },
              {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "ALIAS",
                  "content": {
                    "type": "PATTERN",
                    "value": "([^\\]\\n]|\\][^\"\\n])*"
                  },
                  "named": true,
                  "value": "raw_text"
                }
              },
              {
                "type": "STRING",
                "value": "]\""
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "`\"\"["
              },
              {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "ALIAS",
                  "content": {
                    "type": "PATTERN",
                    "value": "([^\\]\\n]|\\][^\"\\n]|\\]\"[^\"\\n])*"
                  },
                  "named": true,
                  "value": "raw_text"
                }
              },
              {
                "type": "STRING",
                "value": "]\"\""
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "`\"\"\"["
              },
              {
                "type": "FIELD",
                "name": "content",
                "content": {
                  "type": "ALIAS",
                  "content": {
                    "type": "PATTERN",
                    "value": "([^\\]\\n]|\\][^\"\\n]|\\]\"[^\"\\n]|\\]\"\"[^\"\\n])*"
                  },
                  "named": true,
                  "value": "raw_text"
                }
              },
              {
                "type": "STRING",
                "value": "]\"\"\""
              }
            ]
          }
        ]
      }
    },
    "attributes": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "tag",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_tag"
                }
              },
              {
                "type": "FIELD",
                "name": "id",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_id"
                }
              },
              {
                "type": "FIELD",
                "name": "class",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_class"
                }
              },
              {
                "type": "FIELD",
                "name": "pair",
                "content": {
                  "type": "SYMBOL",
                  "name": "attribute_pair"
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "attribute_tag": {
      "type": "SYMBOL",
      "name": "attribute_name"
    },
    "attribute_id": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        }
      ]
    },
    "attribute_class": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "SYMBOL",
          "name": "attribute_name"
        }
      ]
    },
    "attribute_pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_name"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_value"
          }
        }
      ]
    },
    "attribute_name": {
      "type": "PATTERN",
      "value": "[^\\s{}#.=]+"
    },
    "attribute_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^\\s{}\"]+"
        },
        {
          "type": "PATTERN",
          "value": "\"([^\"\\\\]|\\\\.)*\""
        }
      ]
    },
    "introducer_escape": {
      "type": "PREC",
      "value": 4,
      "content": {
        "type": "STRING",
        "value": "``"
      }
    },
    "introducer": {
      "type": "STRING",
      "value": "`"
    },
    "code_marker": {
      "type": "PATTERN",
      "value": "\"+"
    },
    "marker": {
      "type": "PATTERN",
      "value": "[^\\s\\[{`\"]+"
    },
    "inline_kind": {
      "type": "PATTERN",
      "value": "[^\\s\\[{`\"]+"
    },
    "head_separator": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[ \\t]+"
        }
      }
    },
    "indent": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": " +"
        }
      }
    },
    "raw_line": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "text": {
      "type": "PREC",
      "value": 1,
      "content": {
        "type": "PATTERN",
        "value": "[^`\\]\\n]+|\\]"
      }
    },
    "_line_end": {
      "type": "STRING",
      "value": "\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}